{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.3.0",
  "compounds": [
    {
      "name": "Start Flutter Web & Proxy",
      "configurations": ["Flutter Web (Debug)", "Start_Proxy_Server"]
    }
  ],
  "configurations": [
    {
      "name": "smartq (module)",
      "type": "dart",
      "request": "attach"
    },
    {
      "name": "smartq (debug mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug"
    },
    {
      "name": "smartq (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "smartq (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "Flutter Web (Debug)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "deviceId": "chrome",
      //4000 to 4003 multiple instance support
      //eg: "--web-renderer=canvaskit" Render type base on your project
      "args": ["--web-port=4000"]
    },
    {
      "name": "Start_Proxy_Server",
      "type": "node",
      "request": "launch",
      "program": "../smartq_pwa_proxy/proxy-server.js",
      "console": "integratedTerminal",
      "runtimeArgs": ["--inspect=9229"],
      "args": [
        "https://ukdemo.thesmartq.com/" //Target Server URL
      ]
    }
  ]
}
